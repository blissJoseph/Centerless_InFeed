<Window x:Class="Centerless_InFeed.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Centerless_InFeed"
        mc:Ignorable="d"
        Title="MainWindow" Height="1920" Width="1080">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <!-- Row 1 -->
            <RowDefinition Height="60"/>
            <!-- Row 2 -->
            <RowDefinition Height="820"/>
            <!-- Row 3 -->
            <RowDefinition Height="440"/>
            <!-- Row 4 -->
            <RowDefinition Height="400"/>
            <!-- Row 5 -->
            <RowDefinition Height="100"/>
            <!-- Row 6 -->
        </Grid.RowDefinitions>
        
        <!--Fist Row Content-->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <!-- Image -->
            <Image Source="/LOGO.jpg" Width="340" Height="50" Margin="5" RenderTransformOrigin="1,1"/>
            
            <!-- button -->
            <Button Content="Button1" Width="60" Height="60" Margin="5" Canvas.Left="340" Canvas.Top="10" Click="Button_Click_1" />
            <Button Content="Button2" Width="60" Height="60" Margin="5" Canvas.Left="370" Canvas.Top="30" Click="Button_Click_3" />
            <Button Content="Button3" Width="60" Height="60" Margin="5" Canvas.Left="400" Canvas.Top="50" Click="Button_Click_2" />

            <!-- AM/PM Text -->
            <TextBlock x:Name="AmPmTextBlcok" FontSize="14" 
                       HorizontalAlignment="Right" Margin="0,5,20,0"/>
            <!-- Date in dd/mm/yyyy format-->
            <TextBlock x:Name="DateTextBlock" FontSize="14" 
                       HorizontalAlignment="Right" Margin="0,5,20,0"/>


        </StackPanel>

    </Grid>


</Window>
